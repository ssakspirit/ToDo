# Google Gemini API Key
# https://aistudio.google.com 에서 발급
# 여러 키를 쉼표로 구분하여 입력 가능 (예: "key1,key2,key3")
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Microsoft Azure AD Application (Client) ID
# https://portal.azure.com 에서 앱 등록 후 발급받은 클라이언트 ID
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here

# Google Cloud OAuth Client ID
# https://console.cloud.google.com 에서 OAuth 클라이언트 ID 생성
# Calendar API 사용을 위한 클라이언트 ID (형식: xxxxx.apps.googleusercontent.com)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 클라이언트 → 클라이언트 보안 비밀번호
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 공공데이터포털 공휴일 API 키 (한국천문연구원 특일 정보)
# https://www.data.go.kr 에서 회원가입 후 "한국천문연구원_특일 정보" 신청
# 발급받은 "일반 인증키(Encoding)"를 아래에 입력
VITE_HOLIDAY_API_KEY=your_holiday_api_key_here
